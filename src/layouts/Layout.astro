---
export interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description = "Site vitrine heroic fantasy et medieval", image = "/og-image.jpg" } = Astro.props;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:type" content="website" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
		<style is:global>
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			:root {
				--font-medieval: 'Cinzel', serif;
				--font-parchment: 'Crimson Text', serif;
				--font-gothic: 'Cinzel', serif;
				/* Variables de couleurs sombres - The Witcher Style */
				--bg-dominant: #0A0A0A;
				--bg-secondary: #1A1A1A;
				--bg-tertiary: #2A2A2A;
				--accent-royal: #8B7355;
				--accent-action: #4A3C28;
				--accent-magical: #2C1810;
				--text-primary: #E8E0D5;
				--text-secondary: #B8B0A0;
				--border-gold: #6B5D54;
				--glow-gold: rgba(139, 115, 85, 0.3);
				--glow-action: rgba(74, 60, 40, 0.3);
				--glow-magical: rgba(44, 24, 16, 0.3);
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: var(--font-parchment);
				background: linear-gradient(135deg, var(--bg-dominant) 0%, var(--bg-secondary) 50%, var(--bg-dominant) 100%);
				color: var(--text-primary);
				min-height: 100vh;
				position: relative;
			}

			body::before {
				content: '';
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="none" stroke="%23D4AF3710" stroke-width="0.5"/><circle cx="50" cy="50" r="20" fill="none" stroke="%23D4AF3705" stroke-width="0.3"/></svg>');
				background-size: 100px 100px;
				pointer-events: none;
				z-index: -1;
			}

			.btn-hero {
				padding: 1rem 2rem;
				background: linear-gradient(135deg, var(--accent-action), var(--accent-magical));
				color: var(--text-primary);
				font-weight: bold;
				border-radius: 0.25rem;
				border: 2px solid var(--accent-royal);
				box-shadow: 0 4px 15px rgba(114, 47, 55, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.1);
				transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				font-family: var(--font-gothic);
				cursor: pointer;
				text-decoration: none;
				display: inline-block;
				position: relative;
				overflow: hidden;
				text-transform: uppercase;
				letter-spacing: 1px;
				font-size: 0.9rem;
			}

			.btn-hero::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 100%;
				height: 100%;
				background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
				transition: left 0.6s ease;
			}

			.btn-hero:hover::before {
				left: 100%;
			}

			.btn-hero:hover {
				transform: translateY(-3px) scale(1.02);
				box-shadow: 0 8px 25px rgba(114, 47, 55, 0.6), inset 0 1px 0 rgba(255, 255, 255, 0.2);
				border-color: var(--accent-royal);
				background: linear-gradient(135deg, var(--accent-magical), var(--accent-action));
			}

			.btn-secondary {
				padding: 1rem 2rem;
				background: linear-gradient(135deg, var(--bg-secondary), var(--bg-dominant));
				color: var(--accent-royal);
				font-weight: bold;
				border-radius: 0.25rem;
				border: 2px solid var(--accent-royal);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(212, 175, 55, 0.1);
				transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
				font-family: var(--font-gothic);
				cursor: pointer;
				text-decoration: none;
				display: inline-block;
				position: relative;
				overflow: hidden;
				text-transform: uppercase;
				letter-spacing: 1px;
				font-size: 0.9rem;
			}

			.btn-secondary::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 100%;
				height: 100%;
				background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
				transition: left 0.6s ease;
			}

			.btn-secondary:hover::before {
				left: 100%;
			}

			.btn-secondary:hover {
				transform: translateY(-3px) scale(1.02);
				box-shadow: 0 8px 25px rgba(212, 175, 55, 0.3), inset 0 1px 0 rgba(212, 175, 55, 0.2);
				background: linear-gradient(135deg, var(--bg-dominant), var(--bg-secondary));
				color: var(--text-primary);
			}

			.card-medieval {
				background: linear-gradient(135deg, rgba(44, 36, 30, 0.95), rgba(26, 26, 29, 0.95));
				backdrop-filter: blur(10px);
				border: 2px solid var(--border-gold);
				border-radius: 0.5rem;
				padding: 2rem;
				box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6), inset 0 1px 0 rgba(212, 175, 55, 0.1);
				position: relative;
				overflow: hidden;
			}

			.card-medieval::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent-royal), transparent);
			}

			.card-medieval::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent-royal), transparent);
			}

			.text-hero {
				font-family: var(--font-gothic);
				font-size: 3.5rem;
				font-weight: 900;
				background: linear-gradient(135deg, var(--accent-royal), var(--accent-action));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				color: transparent;
				text-shadow: 0 0 30px var(--glow-gold);
				position: relative;
				text-transform: uppercase;
				letter-spacing: 2px;
				line-height: 1.1;
			}

			.text-hero::after {
				content: attr(data-text);
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: linear-gradient(135deg, var(--accent-royal), var(--accent-action));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				z-index: -1;
				filter: blur(10px);
				opacity: 0.4;
			}

			@media (min-width: 768px) {
				.text-hero {
					font-size: 5rem;
				}
			}

			.text-title {
				font-family: var(--font-gothic);
				font-size: 2rem;
				font-weight: 700;
				color: var(--accent-royal);
				text-shadow: 0 0 20px var(--glow-gold);
				text-transform: uppercase;
				letter-spacing: 1px;
				position: relative;
			}

			.text-title::after {
				content: '';
				position: absolute;
				bottom: -10px;
				left: 50%;
				transform: translateX(-50%);
				width: 100px;
				height: 2px;
				background: linear-gradient(90deg, transparent, var(--accent-royal), transparent);
			}

			@media (min-width: 768px) {
				.text-title {
					font-size: 2.5rem;
				}
			}

			.border-medieval {
				border: 2px solid var(--border-gold);
				border-radius: 0.5rem;
				position: relative;
			}

			.border-medieval::before {
				content: '';
				position: absolute;
				top: -1px;
				left: -1px;
				right: -1px;
				bottom: -1px;
				background: linear-gradient(45deg, var(--accent-royal), var(--accent-action), var(--accent-magical), var(--accent-royal));
				border-radius: 0.5rem;
				z-index: -1;
				opacity: 0.3;
			}

			.glow-effect {
				box-shadow: 0 0 40px var(--glow-gold);
			}

			.text-shadow {
				text-shadow: 2px 2px 8px var(--shadow-dark);
			}

			.text-shadow-lg {
				text-shadow: 4px 4px 16px var(--shadow-dark);
			}

			.backdrop-medieval {
				backdrop-filter: blur(15px) brightness(0.6);
			}

			/* Séparateurs décoratifs */
			.divider-celtic {
				height: 3px;
				background: linear-gradient(90deg, transparent, var(--accent-royal), transparent);
				position: relative;
				margin: 2rem 0;
			}

			.divider-celtic::before,
			.divider-celtic::after {
				content: '⚔';
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				color: var(--accent-royal);
				font-size: 1.2rem;
			}

			.divider-celtic::before {
				left: 45%;
			}

			.divider-celtic::after {
				right: 45%;
			}

			/* Classes utilitaires de base */
			.container {
				max-width: 1200px;
				margin: 0 auto;
				padding: 0 1rem;
			}

			.flex {
				display: flex;
			}

			.items-center {
				align-items: center;
			}

			.justify-center {
				justify-content: center;
			}

			.justify-between {
				justify-content: space-between;
			}

			.space-x-2 > * + * {
				margin-left: 0.5rem;
			}

			.space-x-4 > * + * {
				margin-left: 1rem;
			}

			.space-x-8 > * + * {
				margin-left: 2rem;
			}

			.space-y-2 > * + * {
				margin-top: 0.5rem;
			}

			.space-y-4 > * + * {
				margin-top: 1rem;
			}

			.space-y-6 > * + * {
				margin-top: 1.5rem;
			}

			.gap-4 {
				gap: 1rem;
			}

			.gap-6 {
				gap: 1.5rem;
			}

			.gap-8 {
				gap: 2rem;
			}

			.gap-12 {
				gap: 3rem;
			}

			.grid {
				display: grid;
			}

			.grid-cols-1 {
				grid-template-columns: repeat(1, minmax(0, 1fr));
			}

			.grid-cols-2 {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}

			.grid-cols-3 {
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}

			@media (min-width: 768px) {
				.md\:grid-cols-2 {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.md\:grid-cols-3 {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}

				.md\:flex {
					display: flex;
				}

				.md\:text-2xl {
					font-size: 1.5rem;
				}

				.md\:text-4xl {
					font-size: 2.25rem;
				}

				.md\:text-6xl {
					font-size: 3.75rem;
				}
			}

			@media (min-width: 1024px) {
				.lg\:grid-cols-2 {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.lg\:grid-cols-3 {
					grid-template-columns: repeat(3, minmax(0, 1fr));
				}
			}

			.text-center {
				text-align: center;
			}

			.text-white {
				color: white;
			}

			.text-gold {
				color: #FFD700;
			}

			.text-parchment {
				color: #F4E8D0;
			}

			.text-parchment\/80 {
				color: rgba(244, 232, 208, 0.8);
			}

			.text-parchment\/60 {
				color: rgba(244, 232, 208, 0.6);
			}

			.text-parchment\/40 {
				color: rgba(244, 232, 208, 0.4);
			}

			.bg-night {
				background-color: #0F172A;
			}

			.bg-obsidian {
				background-color: #1a1a1a;
			}

			.bg-obsidian\/80 {
				background-color: rgba(26, 26, 26, 0.8);
			}

			.bg-dragon-red {
				background-color: #8B0000;
			}

			.bg-dragon-red\/10 {
				background-color: rgba(139, 0, 0, 0.1);
			}

			.bg-fire {
				background-color: #FF6B35;
			}

			.bg-fire\/10 {
				background-color: rgba(255, 107, 53, 0.1);
			}

			.bg-forest {
				background-color: #228B22;
			}

			.bg-stone {
				background-color: #708090;
			}

			.bg-royal {
				background-color: #4B0082;
			}

			.bg-ice {
				background-color: #E0FFFF;
			}

			.bg-gold {
				background-color: #FFD700;
			}

			.bg-gold\/10 {
				background-color: rgba(255, 215, 0, 0.1);
			}

			.bg-bronze {
				background-color: #CD7F32;
			}

			.bg-bronze\/30 {
				background-color: rgba(205, 127, 50, 0.3);
			}

			.bg-medieval-800\/50 {
				background-color: rgba(52, 58, 32, 0.5);
			}

			.bg-gradient-to-br {
				background-image: linear-gradient(to bottom right, var(--tw-gradient-stops));
			}

			.bg-gradient-to-r {
				background-image: linear-gradient(to right, var(--tw-gradient-stops));
			}

			.bg-gradient-to-t {
				background-image: linear-gradient(to top, var(--tw-gradient-stops));
			}

			.bg-gradient-to-b {
				background-image: linear-gradient(to bottom, var(--tw-gradient-stops));
			}

			.from-night {
				--tw-gradient-from: #0F172A;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(15 23 42 / 0));
			}

			.from-obsidian {
				--tw-gradient-from: #1a1a1a;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(26 26 26 / 0));
			}

			.from-dragon-red {
				--tw-gradient-from: #8B0000;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(139 0 0 / 0));
			}

			.from-fire {
				--tw-gradient-from: #FF6B35;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(255 107 53 / 0));
			}

			.from-forest {
				--tw-gradient-from: #228B22;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(34 139 34 / 0));
			}

			.from-stone {
				--tw-gradient-from: #708090;
				--tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to, rgb(112 128 144 / 0));
